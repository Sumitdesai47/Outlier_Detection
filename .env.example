# Local MySQL — database name: anomaly
# Default local dev (username root, password root):
DATABASE_URL=mysql://root:root@127.0.0.1:3306/anomaly
#
# Optional: dedicated app user after running db/grant_anomaly_user.sql as root:
# DATABASE_URL=mysql://anomaly:anomaly@127.0.0.1:3306/anomaly
#
# See db/MYSQL.md
#
# Flask dev server (python app.py); default in code is 5001 if unset:
# FLASK_PORT=5001
#
# Live Dashboard scheduled jobs (optional):
# SCHEDULED_ANOMALY_ENABLED=1
# SCHEDULED_ANOMALY_START_UTC=2022-12-01T00:00:00
# SCHEDULED_ANOMALY_BACKFILL_MAX=500
