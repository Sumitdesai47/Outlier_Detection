# MySQL is optional and off by default. Excel / multimodel outlier runs work without it.
# ENABLE_MYSQL=1
# DATABASE_URL=mysql://root:root@127.0.0.1:3306/anomaly
#
# Optional dedicated app user after db/grant_anomaly_user.sql:
# DATABASE_URL=mysql://anomaly:anomaly@127.0.0.1:3306/anomaly
#
# See db/MYSQL.md
#
# Flask dev server (python app.py); default in code is 5001 if unset:
# FLASK_PORT=5001
# FLASK_DEBUG=1
# FLASK_USE_RELOADER=0
#   Keep reloader off on Windows (default). Set to 1 only when you need auto-reload
#   and run in a foreground terminal — background runs crash when site-packages change.
#
# Live Dashboard scheduled jobs (optional):
# SCHEDULED_ANOMALY_ENABLED=1
# SCHEDULED_ANOMALY_START_UTC=2022-12-01T00:00:00
# SCHEDULED_ANOMALY_BACKFILL_MAX=500
